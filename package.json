{
  "name": "loan-eligibility-simulator",
  "version": "1.0.0",
  "private": true,
  "description": "Loan Eligibility Simulator — a micro-frontend module built with Vue 3, TypeScript, and Module Federation",
  "scripts": {
    "dev": "pnpm --filter './apps/**' --parallel dev",
    "dev:simulator": "pnpm --filter @loan-simulator/app dev",
    "dev:shell": "pnpm --filter @loan-simulator/shell dev",
    "build": "pnpm --filter './apps/**' build",
    "build:simulator": "pnpm --filter @loan-simulator/app build",
    "build:shell": "pnpm --filter @loan-simulator/shell build",
    "lint": "pnpm --filter './apps/**' --parallel lint",
    "type-check": "pnpm --filter './apps/**' --parallel type-check",
    "preview": "pnpm --filter @loan-simulator/app preview"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
